---
interface Props {
	variant?: 'logo' | 'wave';
}
const { variant = 'logo' } = Astro.props;

const logo = String.raw`███████╗ █████╗ ██████╗  ██████╗ ██╗  ██╗ █████╗ ████████╗
██╔════╝██╔══██╗██╔══██╗██╔═══██╗██║  ██║██╔══██╗╚══██╔══╝
███████╗███████║██████╔╝██║   ██║███████║███████║   ██║
╚════██║██╔══██║██╔══██╗██║   ██║██╔══██║██╔══██║   ██║
███████║██║  ██║██████╔╝╚██████╔╝██║  ██║██║  ██║   ██║
╚══════╝╚═╝  ╚═╝╚═════╝  ╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═╝   ╚═╝`;

const wave = String.raw`╭──────────────────────────────╮
│ hello — sabohat dev journal  │
│ ai · til · ovoz · fikrlar    │
╰──────────────────────────────╯`;

const art = variant === 'logo' ? logo : wave;
// logo is 60 chars wide; we use a container-query-free trick: cqi/cqw via CSS
// but simplest is clamp() based on viewport width to keep it fitting.
---

<div class="my-2 w-full">
	<pre
		class="ascii text-ink leading-[1.05] select-none whitespace-pre"
		style="font-size: clamp(6px, 2.1vw, 14px);"
	>{art}</pre>
	{variant === 'logo' && (
		<div class="mt-2 font-mono text-xs sm:text-sm text-muted">
			~ samantha · uzbek voice · v0.1 ~
		</div>
	)}
</div>
