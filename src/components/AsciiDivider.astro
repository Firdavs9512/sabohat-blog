---
interface Props {
	style?: 'double' | 'single' | 'dashed' | 'dotted' | 'plus';
	label?: string;
}
const { style = 'single', label } = Astro.props;

const chars: Record<string, string> = {
	double: '═',
	single: '─',
	dashed: '╌',
	dotted: '·',
	plus: '+',
};
const ch = chars[style];
const fill = ch.repeat(200);
---

<div class="ascii my-6 text-muted text-[10px] sm:text-xs leading-tight select-none w-full overflow-hidden">
	{label ? (
		<div class="flex items-center gap-2 min-w-0 w-full">
			<span class="shrink-0">{ch.repeat(3)}</span>
			<span class="font-mono uppercase tracking-widest shrink-0">[ {label} ]</span>
			<span class="block grow overflow-hidden whitespace-nowrap min-w-0">{fill}</span>
		</div>
	) : (
		<div class="w-full whitespace-nowrap overflow-hidden">{fill}</div>
	)}
</div>
