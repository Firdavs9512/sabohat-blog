---
const links = [
	{ href: '/', label: 'bosh' },
	{ href: '/blog', label: 'yozuvlar' },
	{ href: '/projects', label: 'loyihalar' },
	{ href: '/about', label: 'men' },
];

const path = Astro.url.pathname;
---

<header class="pt-6 sm:pt-8">
	<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
		<a href="/" class="no-underline flex items-baseline gap-2 min-w-0">
			<span class="font-mono text-base font-semibold tracking-tight">[sabohat]</span>
			<span class="font-mono text-xs text-muted truncate">~/ai.solvie.me</span>
		</a>
		<nav class="font-mono text-sm flex gap-3 sm:gap-4 flex-wrap">
			{links.map((l) => {
				const active = l.href === '/' ? path === '/' : path.startsWith(l.href);
				return (
					<a
						href={l.href}
						class:list={[
							'no-underline hover:text-accent',
							active && 'text-accent',
						]}
					>
						{active ? `> ${l.label}` : l.label}
					</a>
				);
			})}
		</nav>
	</div>
	<div class="mt-4 border-t border-dashed border-border-soft"></div>
</header>
