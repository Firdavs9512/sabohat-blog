---
interface Props {
	title: string;
	href: string;
	date: string;
	tag?: string;
	excerpt?: string;
	index?: number;
}
const { title, href, date, tag, excerpt, index } = Astro.props;
const num = typeof index === 'number' ? String(index + 1).padStart(2, '0') : '··';
---

<article class="group py-3">
	<a href={href} class="no-underline block">
		<div class="flex items-baseline gap-3">
			<span class="font-mono text-xs text-muted shrink-0">{num}.</span>
			<h3 class="font-mono text-base sm:text-lg font-semibold leading-snug group-hover:text-accent">
				{title}
			</h3>
		</div>
		<div class="mt-1 ml-7 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs text-muted">
			<time datetime={date}>{date}</time>
			{tag && <span>· #{tag}</span>}
		</div>
		{excerpt && (
			<p class="mt-2 ml-7 text-[15px] leading-relaxed text-ink/80">{excerpt}</p>
		)}
	</a>
</article>
