---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	publishedTime?: string;
	tag?: string;
}

const {
	title = "Sabohat — AI tadqiqot kundaligi",
	description = "Sabohat (Samantha) — miyaga o'xshash ishlovchi SNN AI modeli. O'zbek tili uchun, self-learning va continual learning fokusida olib borilayotgan ish kundaligi.",
	image = '/og-default.png',
	type = 'website',
	publishedTime,
	tag,
} = Astro.props;

const siteName = 'Sabohat';
const fullTitle = title.includes('Sabohat') ? title : `${title} · Sabohat`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://ai.solvie.me').toString();
const ogImage = new URL(image, Astro.site ?? 'https://ai.solvie.me').toString();
---

<!doctype html>
<html lang="uz">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="alternate" type="application/rss+xml" title={`${siteName} RSS`} href="/rss.xml" />

		<meta name="author" content="Firdavs" />
		<meta name="robots" content="index, follow, max-image-preview:large" />
		<meta name="theme-color" content="#f6f6ef" />
		<meta name="keywords" content="Sabohat, Samantha, AI, SNN, spiking neural network, sun'iy intellekt, o'zbek tili, neural network, continual learning, brain-inspired AI, machine learning" />

		<meta property="og:type" content={type} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content={fullTitle} />
		<meta property="og:locale" content="uz_UZ" />
		{publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{tag && <meta property="article:tag" content={tag} />}

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		{import.meta.env.PROD && (
			<>
				<script async src="https://www.googletagmanager.com/gtag/js?id=G-ELP4RXEH5K"></script>
				<script is:inline>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', 'G-ELP4RXEH5K');
				</script>
			</>
		)}
	</head>
	<body class="bg-bg text-ink overflow-x-hidden">
		<div class="mx-auto max-w-3xl px-4 sm:px-8">
			<Header />
			<main class="py-8 sm:py-10">
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
