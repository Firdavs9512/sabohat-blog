---
import Layout from '../../layouts/Layout.astro';
import AsciiDivider from '../../components/AsciiDivider.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'en' as const;
const t = useTranslations(lang);
---

<Layout lang={lang} title={t('404.title')} description={t('404.description')}>
	<pre class="ascii text-sm sm:text-base text-muted leading-tight select-none">{t('404.art')}</pre>

	<AsciiDivider style="dashed" />

	<p class="text-[17px] leading-relaxed">
		{t('404.text')}
	</p>
	<div class="mt-4 font-mono text-sm">
		<a href="/en/" class="no-underline hover:text-accent">{t('404.home')}</a>
	</div>
</Layout>
