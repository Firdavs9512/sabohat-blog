---
import { render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import AsciiDivider from '../../../components/AsciiDivider.astro';
import { useTranslations } from '../../../i18n/ui';
import { getEntrySlug, getPostsByLang } from '../../../i18n/blog';

export async function getStaticPaths() {
	const posts = await getPostsByLang('en');
	return posts.map((post) => ({
		params: { slug: getEntrySlug(post) },
		props: { post },
	}));
}

const { post } = Astro.props;
const lang = 'en' as const;
const t = useTranslations(lang);
const { Content } = await render(post);

const slug = getEntrySlug(post);
const dateStr = post.data.date.toISOString().slice(0, 10);
const pubISO = post.data.date.toISOString();
const description =
	post.data.excerpt ?? `${post.data.title} — Sabohat AI research notes.`;
const canonical = new URL(`/en/blog/${slug}/`, Astro.site ?? 'https://ai.solvie.me').toString();

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: post.data.title,
	description,
	datePublished: pubISO,
	author: {
		'@type': 'Person',
		name: 'Firdavs',
	},
	publisher: {
		'@type': 'Organization',
		name: 'Sabohat',
		url: Astro.site?.toString() ?? 'https://ai.solvie.me',
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': canonical,
	},
	inLanguage: lang,
	keywords: post.data.tag,
};
---

<Layout
	lang={lang}
	title={`${post.data.title} · Sabohat`}
	description={description}
	type="article"
	publishedTime={pubISO}
	tag={post.data.tag}
>
	<a href="/en/blog" class="font-mono text-xs text-muted no-underline hover:text-accent">{t('blog.back')}</a>

	<article class="mt-4">
		<header>
			<h1 class="text-2xl sm:text-3xl leading-tight">{post.data.title}</h1>
			<div class="mt-3 flex flex-wrap items-center gap-x-3 font-mono text-xs text-muted">
				<time datetime={dateStr}>{dateStr}</time>
				{post.data.tag && <span>· #{post.data.tag}</span>}
			</div>
		</header>

		<AsciiDivider style="dashed" />

		<div class="post-body">
			<Content />
		</div>
	</article>

	<AsciiDivider style="double" />

	<a href="/en/blog" class="font-mono text-xs text-muted no-underline hover:text-accent">{t('blog.backAll')}</a>

	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Layout>
