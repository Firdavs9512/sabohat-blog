---
import Layout from '../../../layouts/Layout.astro';
import AsciiDivider from '../../../components/AsciiDivider.astro';
import PostCard from '../../../components/PostCard.astro';
import { useTranslations } from '../../../i18n/ui';
import { entryHref, getPostsByLang } from '../../../i18n/blog';

const lang = 'en' as const;
const t = useTranslations(lang);
const posts = await getPostsByLang(lang);
---

<Layout
	lang={lang}
	title="Posts · Sabohat"
	description={t('blog.subtitle').replace('// ', '')}
>
	<h1 class="text-2xl">{t('blog.heading')}</h1>
	<p class="mt-2 font-mono text-sm text-muted">
		{t('blog.subtitle')}
	</p>

	<AsciiDivider style="single" label={`${posts.length} ${t('blog.countSuffix')}`} />

	<section class="divide-y divide-border-soft">
		{posts.map((p, i) => (
			<PostCard
				index={i}
				title={p.data.title}
				href={entryHref(p)}
				date={p.data.date.toISOString().slice(0, 10)}
				tag={p.data.tag}
				excerpt={p.data.excerpt}
			/>
		))}
	</section>
</Layout>
