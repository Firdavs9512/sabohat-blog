---
import Layout from '../../layouts/Layout.astro';
import AsciiBanner from '../../components/AsciiBanner.astro';
import InfoCard from '../../components/InfoCard.astro';
import AsciiDivider from '../../components/AsciiDivider.astro';
import PostCard from '../../components/PostCard.astro';
import { useTranslations } from '../../i18n/ui';
import { entryHref, getPostsByLang } from '../../i18n/blog';

const lang = 'en' as const;
const t = useTranslations(lang);
const posts = (await getPostsByLang(lang)).slice(0, 5);
---

<Layout lang={lang}>
	<AsciiBanner variant="logo" />

	<section class="mt-2">
		<p class="text-[17px] leading-relaxed">
			<span class="font-mono text-muted">&gt; </span>
			<strong>Sabohat</strong> — a brain-inspired AI model based on
			<abbr title="Spiking Neural Network">SNN</abbr>. The goal — make
			the model learn on its own and significantly reduce the
			<abbr title="Continual Learning">CL</abbr> problem (catastrophic
			forgetting).
		</p>

		<InfoCard
			items={[
				{ label: t('home.info.architecture'), value: t('home.info.architectureValue') },
				{ label: t('home.info.goal'), value: t('home.info.goalValue') },
				{ label: t('home.info.experiments'), value: '200+' },
				{ label: t('home.info.site'), value: 'ai.solvie.me', href: 'https://ai.solvie.me' },
			]}
		/>
	</section>

	<AsciiDivider style="double" label={t('home.divider.recent')} />

	<section class="divide-y divide-border-soft">
		{posts.map((p, i) => (
			<PostCard
				index={i}
				title={p.data.title}
				href={entryHref(p)}
				date={p.data.date.toISOString().slice(0, 10)}
				tag={p.data.tag}
				excerpt={p.data.excerpt}
			/>
		))}
	</section>

	<div class="mt-6 font-mono text-xs text-muted">
		<a href="/en/blog" class="no-underline hover:text-accent">{t('home.allPosts')}</a>
	</div>
</Layout>
