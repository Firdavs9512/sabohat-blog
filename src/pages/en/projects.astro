---
import Layout from '../../layouts/Layout.astro';
import AsciiDivider from '../../components/AsciiDivider.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'en' as const;
const t = useTranslations(lang);

const projects = [
	{
		name: 'sabohat',
		status: t('projects.statusActive'),
		desc: 'A brain-inspired AI model based on SNN (Spiking Neural Network). Aimed at self-learning and reducing the continual learning problem. 200+ experiments.',
		link: 'https://ai.solvie.me',
	},
	{
		name: 'solvie',
		status: t('projects.statusActive'),
		desc: 'The main domain hosting Sabohat and other AI experiments.',
		link: 'https://solvie.me',
	},
];
---

<Layout lang={lang} title={t('projects.title')} description={t('projects.description')}>
	<h1 class="text-2xl">{t('projects.heading')}</h1>
	<p class="mt-2 font-mono text-sm text-muted">{t('projects.subtitle')}</p>

	<AsciiDivider style="single" />

	<div class="space-y-6">
		{projects.map((p) => (
			<article class="border-l-2 border-border pl-4">
				<div class="flex flex-wrap items-baseline gap-x-3">
					<h2 class="font-mono text-lg font-semibold">
						<a href={p.link} class="no-underline hover:text-accent">{p.name}</a>
					</h2>
					<span class="font-mono text-xs text-muted uppercase tracking-widest">[{p.status}]</span>
				</div>
				<p class="mt-1 text-[16px] leading-relaxed">{p.desc}</p>
				<a href={p.link} class="mt-2 inline-block font-mono text-xs no-underline hover:text-accent text-muted">
					→ {p.link}
				</a>
			</article>
		))}
	</div>
</Layout>
