---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import AsciiBanner from '../components/AsciiBanner.astro';
import InfoCard from '../components/InfoCard.astro';
import AsciiDivider from '../components/AsciiDivider.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 5);
---

<Layout
	title="Sabohat — AI tadqiqot kundaligi"
	description="Sabohat (Samantha) — miyaga o'xshash SNN AI modeli ustida olib borilayotgan tadqiqot. O'zbek tili uchun, self-learning va continual learning fokusida ishlovchi loyiha kundaligi."
>
	<AsciiBanner variant="logo" />

	<section class="mt-2">
		<p class="text-[17px] leading-relaxed">
			<span class="font-mono text-muted">&gt; </span>
			<strong>Sabohat</strong> —
			<abbr title="Spiking Neural Network">SNN</abbr> asosida ishlaydigan,
			miyaga o'xshash AI model. Maqsad — modelni o'z-o'zidan o'rgana
			oladigan holatga olib chiqish va
			<abbr title="Continual Learning">CL</abbr> muammosini (catastrophic
			forgetting) sezilarli darajada kamaytirish.
		</p>

		<InfoCard
			items={[
				{ label: 'arxitektura', value: 'SNN · miyaga o\'xshash · spike-based' },
				{ label: 'maqsad', value: 'o\'z-o\'zidan o\'rganish + CL forgetting kamaytirish' },
				{ label: 'sinovlar', value: '200+' },
				{ label: 'sayt', value: 'ai.solvie.me', href: 'https://ai.solvie.me' },
			]}
		/>
	</section>

	<AsciiDivider style="double" label="so'nggi yozuvlar" />

	<section class="divide-y divide-border-soft">
		{posts.map((p, i) => (
			<PostCard
				index={i}
				title={p.data.title}
				href={`/blog/${p.id}`}
				date={p.data.date.toISOString().slice(0, 10)}
				tag={p.data.tag}
				excerpt={p.data.excerpt}
			/>
		))}
	</section>

	<div class="mt-6 font-mono text-xs text-muted">
		<a href="/blog" class="no-underline hover:text-accent">→ barcha yozuvlar</a>
	</div>
</Layout>
